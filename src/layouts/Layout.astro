---
import '../styles/global.css'

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es" class="dark">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title}</title>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700;900&display=swap" rel="stylesheet">
        
        <script is:inline>
          const theme = (() => {
            // 1. Si el usuario ya eligió un tema antes y quedó guardado, lo respetamos
            if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
              return localStorage.getItem('theme');
            }
            // 2. Si es su primera vez o está en incógnito, forzamos el modo oscuro siempre
            return 'dark';
          })();
          
          if (theme === 'light') {
            document.documentElement.classList.remove('dark');
          } else {
            document.documentElement.classList.add('dark');
            // Guardamos el modo oscuro como su nueva preferencia base
            window.localStorage.setItem('theme', 'dark');
          }
        </script>
    </head>
    <body class="bg-zinc-50 dark:bg-[#0a0a0a] text-zinc-900 dark:text-zinc-100 font-['Inter',sans-serif] selection:bg-purple-500/30 overflow-x-hidden transition-colors duration-500">
        <slot />
    </body>
</html>